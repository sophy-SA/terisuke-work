{
  "permissions": {
    "allow": [
      "Bash(biome:*)",
      "Bash(black:*)",
      "Bash(cargo clippy:*)",
      "Bash(cat:*)",
      "Bash(eslint:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(my-custom-tool:*)",
      "Bash(prettier:*)",
      "Bash(pwd:*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(ruff:*)",
      "Bash(rustfmt:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Glob(**)",
      "Grep(**)",
      "Read(**)"
    ],
    "deny": [
      "Bash(rm -rf /:*)"
    ]
  },
  "theme": "dark",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'user-custom startup'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json"
}
