{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(biome:*)",
      "Bash(prettier:*)",
      "Bash(eslint:*)",
      "Bash(gofmt:*)",
      "Bash(go vet:*)",
      "Bash(rustfmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(jq:*)",
      "Bash(python3 -m json.tool:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
