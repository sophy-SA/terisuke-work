{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(jupyter:*)",
      "Bash(jupyter nbconvert:*)",
      "Bash(jupyter lab:*)",
      "Bash(jupyter notebook:*)",
      "Bash(nbstripout:*)",
      "Bash(papermill:*)",
      "Bash(pytest:*)",
      "Bash(pytest -k:*)",
      "Bash(python -m pytest:*)",
      "Bash(mypy:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(black:*)",
      "Bash(dvc status:*)",
      "Bash(dvc diff:*)",
      "Bash(dvc add:*)",
      "Bash(dvc push:*)",
      "Bash(dvc pull:*)",
      "Bash(dvc repro:*)",
      "Bash(dvc dag:*)",
      "Bash(mlflow:*)",
      "Bash(wandb:*)",
      "Bash(uv pip:*)",
      "Bash(pip list:*)",
      "Bash(pip freeze:*)",
      "Bash(pip install:*)",
      "Bash(conda env:*)",
      "Bash(huggingface-cli:*)",
      "Bash(great_expectations:*)",
      "Bash(dbt test:*)",
      "Bash(dbt run:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-large-artifact.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-notebook-output.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
